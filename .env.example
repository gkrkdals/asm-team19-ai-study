# ── LLM 프로바이더 (solar | openai) ─────────────────────────────────
LLM_PROVIDER=solar

# ── Upstage Solar (기본 권장) ─────────────────────────────────────────
SOLAR_API_KEY=up_...
SOLAR_BASE_URL=https://api.upstage.ai/v1
SOLAR_MODEL=solar-pro

# ── OpenAI (대체 프로바이더) ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Tavily Search ─────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── ChromaDB (Docker 외부 실행 시) ────────────────────────────────────
# CHROMA_HOST=localhost
# CHROMA_PORT=8002
